    {
      "id": 30,
      "type": "row",
      "title": "💾 Disk",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },

    {
      "id": 31,
      "type": "bargauge",
      "title": "Disk Usage by Mountpoint",
      "description": "All filesystems across both nodes. Red = > 85% used.",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|fuse.lxcfs\", mountpoint!~\"/boot.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|fuse.lxcfs\", mountpoint!~\"/boot.*\"} * 100)",
          "legendFormat": "{{node}} {{mountpoint}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 32,
      "type": "timeseries",
      "title": "Disk I/O — Both Nodes",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{node=\"control\", device=\"sda\"}[2m])",
          "legendFormat": "master1 read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{node=\"control\", device=\"sda\"}[2m])",
          "legendFormat": "master1 write",
          "refId": "B"
        },
        {
          "expr": "rate(node_disk_read_bytes_total{node=\"compute\", device=~\"nvme.*\"}[2m])",
          "legendFormat": "master2 NVMe read",
          "refId": "C"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{node=\"compute\", device=~\"nvme.*\"}[2m])",
          "legendFormat": "master2 NVMe write",
          "refId": "D"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 40,
