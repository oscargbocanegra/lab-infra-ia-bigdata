        {
          "expr": "rate(node_network_transmit_bytes_total{node=\"compute\", device=\"eth0\"}[2m]) * 8",
          "legendFormat": "master2 tx",
          "refId": "D"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    {
      "id": 50,
      "type": "row",
      "title": "🎮 GPU — master2 (RTX 2080 Ti)",
