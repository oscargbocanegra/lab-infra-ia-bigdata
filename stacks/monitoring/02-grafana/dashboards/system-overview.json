      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{node=\"control\"}",
          "legendFormat": "master1 available",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{node=\"compute\"}",
          "legendFormat": "master2 available",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
