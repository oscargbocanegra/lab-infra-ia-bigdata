    {
      "id": 23,
      "type": "timeseries",
      "title": "RAM Available — Both Nodes",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
