# =============================================================================
# Template: ~/.config/llm/apis.env  — Lab Infra IA & Big Data
#
# Copiar este archivo a:  ~/work/.config/llm/apis.env
# El archivo real (*.env) está en .gitignore y no se sube al repo.
#
# IMPORTANTE — Desde JupyterHub (overlay interno de Swarm):
#   - Usar siempre la URL interna: http://ollama:11434
#   - La IP publicada del host (192.168.80.200:11434) NO es alcanzable
#     desde dentro del network namespace del contenedor Swarm.
#   - No se necesita Basic Auth en la red interna.
#
# Para acceso externo (Postman desde tu equipo, curl desde fuera del cluster):
#   - Usar: https://ollama.sexydad  con Basic Auth.
#   - O la IP directa 192.168.80.200:11434 si estás en 192.168.80.0/24
#     y accedés desde fuera del overlay (ej: equipo físico, no contenedor).
# =============================================================================

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL interna del overlay Swarm — correcta para notebooks en JupyterHub.
# No cambiar a la IP del host; eso causa ConnectTimeout desde el contenedor.
OLLAMA_BASE_URL=http://ollama:11434

# Credenciales opcionales.
# Solo necesarias cuando OLLAMA_BASE_URL apunta al endpoint externo
# (https://ollama.sexydad) que pasa por el middleware BasicAuth de Traefik.
# Dejar comentadas para uso interno.
# OLLAMA_USERNAME=tu_usuario
# OLLAMA_PASSWORD=tu_password

# ── Postgres ──────────────────────────────────────────────────────────────────
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=tu_base
# POSTGRES_USER=tu_usuario
# POSTGRES_PASSWORD=tu_password

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
# MINIO_ENDPOINT=http://minio_minio:9000
# MINIO_ACCESS_KEY=tu_access_key
# MINIO_SECRET_KEY=tu_secret_key
