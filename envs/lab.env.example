# =============================================================
# Lab Global Environment — /etc/lab/lab.env
# =============================================================
# PURPOSE:
#   Global lab variables. Controls the active LLM model for ALL
#   stacks from ONE place — without editing individual stack.yml files.
#
# INSTALL on master1:
#   sudo mkdir -p /etc/lab
#   sudo cp envs/lab.env.example /etc/lab/lab.env
#   sudo chmod 644 /etc/lab/lab.env
#
# ACTIVATE in session:
#   source /etc/lab/lab.env
#
# ACTIVATE automatically (add to ~/.bashrc):
#   echo "source /etc/lab/lab.env" >> ~/.bashrc
#
# HOW TO SWITCH MODEL (with full redeploy — propagates to all stacks):
#   sudo nano /etc/lab/lab.env     # change LAB_LLM_MODEL
#   source /etc/lab/lab.env
#   docker stack deploy -c stacks/ai-ml/06-agent/stack.yml agent
#   docker stack deploy -c stacks/ai-ml/04-rag-api/stack.yml rag-api
#   docker stack deploy -c stacks/ai-ml/01-jupyter/stack.yml jupyter
#
# HOW TO SWITCH MODEL (single service, no redeploy — Portainer path):
#   Portainer -> Services -> agent_agent -> Environment -> edit AGENT_MODEL -> Update
#
# HOW IT WORKS INTERNALLY:
#   stack.yml files use ${VAR:-fallback} syntax:
#     AGENT_MODEL: "${LAB_LLM_MODEL:-gemma4:26b}"
#   If the variable is exported -> uses its value.
#   If NOT exported -> uses the hardcoded fallback (gemma4:26b).
#   This guarantees deploy never fails even if you forget to source.
# =============================================================

# -- LLM Model ------------------------------------------------
# Used by: Agent (router + synthesizer + SQL), RAG API, JARVIS
# Options tested on RTX 2080 Ti (11 GB VRAM):
#   gemma4:26b  MoE, 3.8B active, ~10.5 GB VRAM — best quality, slower
#   gemma4:e4b  Dense, 4.5B effective, ~6.5 GB VRAM — faster, less capable
#   gemma4:e2b  Edge, 2.3B effective, ~5 GB VRAM — fastest, lowest quality
LAB_LLM_MODEL=gemma4:26b

# -- Embedding Model ------------------------------------------
# Used by: RAG API (ingest + query), Agent (embed tool)
# WARNING: changing this model requires full Qdrant re-index.
# Collections have fixed dimensions — they are NOT compatible across models.
#   bge-m3            1024 dims, multi-lingual, 8K ctx  <- ACTIVE
#   nomic-embed-text   768 dims  (legacy collections)
LAB_EMBED_MODEL=bge-m3
LAB_EMBED_DIMS=1024

# -- JARVIS (JupyterLab chat panel + %%JARVIS magic) ----------
# Format required by jupyter-ai provider: "ollama:<model_name>"
# Use a fast code-specialized model here — JARVIS is interactive (low latency matters).
# gemma4:26b is too slow for interactive use (~16 tok/s). qwen2.5-coder:14b hits
# ~25-30 tok/s and is fine-tuned for code generation, reasoning, and fixing.
LAB_JARVIS_MODEL=ollama:qwen2.5-coder:14b

# -- Ollama endpoint ------------------------------------------
# Direct IP of master2 — used by services running on master1
LAB_OLLAMA_URL=http://192.168.80.200:11434

# -- Ollama Performance Tuning --------------------------------
# These control inference behavior for the active model.
# Redeploy stacks/ai-ml/02-ollama/stack.yml after changing.
#
# LAB_OLLAMA_NUM_PARALLEL:
#   Number of parallel inference slots Ollama reserves in VRAM.
#   Each slot pre-allocates KV cache (even when idle).
#   Single-user lab -> 1 is optimal. Set to 2-4 only if running
#   concurrent agent + RAG + JARVIS requests simultaneously.
#   Default: 1
LAB_OLLAMA_NUM_PARALLEL=1
#
# LAB_OLLAMA_KV_CACHE_TYPE:
#   Precision of the KV cache stored in VRAM during inference.
#   f16  -> full half-precision, highest quality, most VRAM  (~800MB/slot)
#   q8_0 -> 8-bit quantized, negligible quality loss, ~400MB/slot saved
#   q4_0 -> 4-bit quantized, small quality loss, max VRAM savings
#   With gemma4:26b at 93% VRAM, q8_0 is the right tradeoff.
#   Default: q8_0
LAB_OLLAMA_KV_CACHE_TYPE=q8_0
