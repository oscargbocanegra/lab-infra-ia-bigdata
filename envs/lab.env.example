# =============================================================
# Lab Global Environment — /etc/lab/lab.env
# =============================================================
# PROPÓSITO:
#   Archivo de variables globales del laboratorio.
#   Controla el modelo LLM activo para TODOS los stacks
#   desde UN solo lugar — sin tocar ningún stack.yml.
#
# INSTALACIÓN en master1:
#   sudo mkdir -p /etc/lab
#   sudo cp envs/lab.env.example /etc/lab/lab.env
#   sudo chmod 644 /etc/lab/lab.env
#
# ACTIVAR en la sesión:
#   source /etc/lab/lab.env
#
# ACTIVAR automáticamente (agregar a /root/.bashrc o ~/.bashrc):
#   echo "source /etc/lab/lab.env" >> ~/.bashrc
#
# CÓMO CAMBIAR DE MODELO (sin redeploy de stacks):
#   Opción A — Portainer (más rápido, solo ese servicio):
#     Portainer → Services → agent_agent → Environment
#     → editar AGENT_MODEL → Update
#
#   Opción B — Redeploy completo (propaga a todos):
#     sudo nano /etc/lab/lab.env  # cambiar LAB_LLM_MODEL
#     source /etc/lab/lab.env
#     docker stack deploy -c stacks/ai-ml/06-agent/stack.yml agent
#     docker stack deploy -c stacks/ai-ml/04-rag-api/stack.yml rag-api
#     docker stack deploy -c stacks/ai-ml/01-jupyter/stack.yml jupyter
#
# CÓMO FUNCIONA INTERNAMENTE:
#   Los stack.yml usan sintaxis ${VAR:-fallback}:
#     AGENT_MODEL: "${LAB_LLM_MODEL:-gemma4:26b}"
#   Si la variable está exportada → usa su valor.
#   Si NO está exportada → usa el fallback (gemma4:26b).
#   Esto garantiza que el deploy NUNCA falla aunque olvides sourcear.
# =============================================================

# ── LLM Principal ─────────────────────────────────────────────
# Modelo usado por: Agent (router+synthesizer+SQL), RAG API, JARVIS
# Opciones probadas en RTX 2080 Ti (11 GB VRAM):
#   gemma4:26b   → MoE, 4B activos, ~9 GB VRAM, RECOMENDADO
#   gemma4:e4b   → Dense, 4.5B efectivos, ~6 GB VRAM, más headroom
#   qwen3:8b     → Dense, 5.2 GB disco, ~5 GB VRAM, buena alternativa
#   gemma4:e2b   → Edge, 2.3B, ~5 GB VRAM, más rápido, menos calidad
LAB_LLM_MODEL=gemma4:26b

# ── Modelo de Embeddings ──────────────────────────────────────
# Modelo usado por: RAG API (ingest + query), Agent (embed)
# IMPORTANTE: Si cambias este modelo, debés re-indexar Qdrant.
# Las colecciones existentes tienen dimensiones fijas.
#   bge-m3        → 1024 dims, multi-lingual, 8K ctx  ← ACTIVO
#   nomic-embed-text → 768 dims  (colecciones legacy)
LAB_EMBED_MODEL=bge-m3
LAB_EMBED_DIMS=1024

# ── JARVIS (JupyterLab chat panel + %%JARVIS magic) ───────────
# Formato requerido por jupyter-ai: "ollama:<model_name>"
LAB_JARVIS_MODEL=ollama:gemma4:26b

# ── Ollama endpoint ───────────────────────────────────────────
# IP directa de master2 — usado por servicios en master1
LAB_OLLAMA_URL=http://192.168.80.200:11434
